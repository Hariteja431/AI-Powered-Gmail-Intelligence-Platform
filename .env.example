# Google OAuth Credentials (for Gmail API access)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google

# AI API Keys
# Gemini API keys can be a single key or a comma-separated list of keys for rate-limit rotation
GEMINI_API_KEYS=your_gemini_key_1,your_gemini_key_2
# Optional NVIDIA NIM config if utilizing NIM for specific embedding models
NVIDIA_NIM_API_KEY=your_nvidia_nim_api_key_here
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Security
# A random 64-character hex string (32 bytes) used to encrypt the Google OAuth refresh tokens before storing in the database
TOKEN_ENCRYPTION_KEY=a_64_character_random_hex_string_here

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
